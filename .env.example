# Backend API base URL (no trailing slash). Must match backend mount path.
# Example: if backend runs on port 5000 and uses path /2026/beautician/backend/api
# On Vercel (HTTPS admin), use an https:// API URL — http:// causes mixed content and blocked GETs.
VITE_API_URL=http://localhost:5000/2026/beautician/backend/api
